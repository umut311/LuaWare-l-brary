--// Pages
local Pages = {}
local CurrentPage

local function CreatePage(Name)

    local Page = Instance.new("Frame")
    Page.Parent = Main
    Page.BackgroundTransparency = 1
    Page.Position = UDim2.new(0,115,0,0)
    Page.Size = UDim2.new(1,-125,1,0)
    Page.Visible = false

    -- Container for UI Elements
    local Scroll = Instance.new("ScrollingFrame")
    Scroll.Parent = Page
    Scroll.BackgroundTransparency = 1
    Scroll.Position = UDim2.new(0, 5, 0, 50)
    Scroll.Size = UDim2.new(1, -10, 1, -55)
    Scroll.ScrollBarThickness = 3
    Scroll.ScrollBarImageColor3 = Theme.Accent
    Scroll.BorderSizePixel = 0
    Scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y

    local Layout = Instance.new("UIListLayout")
    Layout.Parent = Scroll
    Layout.Padding = UDim.new(0, 8)
    Layout.SortOrder = Enum.SortOrder.LayoutOrder

    Pages[Name] = {Frame = Page, Scroll = Scroll}

    return Scroll
end

local function SwitchPage(Name)

    if CurrentPage then
        Pages[CurrentPage].Frame.Visible = false
    end

    CurrentPage = Name

    local PageData = Pages[Name]
    PageData.Frame.Visible = true

    for _,v in pairs(PageData.Frame:GetDescendants()) do

        if v:IsA("TextLabel") or v:IsA("TextButton") then

            v.TextTransparency = 1

            TS:Create(v,TweenInfo.new(0.2),{
                TextTransparency = 0
            }):Play()
        end
    end
end

