    ToggleStroke.Parent = ToggleMain
    ToggleStroke.Color = Theme.Border
    ToggleStroke.Thickness = 1

    local Label = Instance.new("TextLabel")
    Label.Parent = ToggleMain
    Label.BackgroundTransparency = 1
    Label.Position = UDim2.new(0, 10, 0, 0)
    Label.Size = UDim2.new(0.7, 0, 1, 0)
    Label.Font = Enum.Font.GothamMedium
    Label.Text = Text
    Label.TextSize = 13
    Label.TextColor3 = Theme.Text
    Label.TextXAlignment = Enum.TextXAlignment.Left

    local SwitchBg = Instance.new("Frame")
    SwitchBg.Parent = ToggleMain
    SwitchBg.AnchorPoint = Vector2.new(1, 0.5)
    SwitchBg.Position = UDim2.new(1, -10, 0.5, 0)
    SwitchBg.Size = UDim2.new(0, 34, 0, 18)
    SwitchBg.BackgroundColor3 = Theme.Main
    Instance.new("UICorner", SwitchBg).CornerRadius = UDim.new(1, 0)

    local SwitchStroke = Instance.new("UIStroke")
    SwitchStroke.Parent = SwitchBg
    SwitchStroke.Color = Theme.Border
    SwitchStroke.Thickness = 1

    local Circle = Instance.new("Frame")
    Circle.Parent = SwitchBg
    Circle.AnchorPoint = Vector2.new(0, 0.5)
    Circle.Position = UDim2.new(0, 2, 0.5, 0)
    Circle.Size = UDim2.new(0, 14, 0, 14)
    Circle.BackgroundColor3 = Theme.TextDark
    Instance.new("UICorner", Circle).CornerRadius = UDim.new(1, 0)

    local Btn = Instance.new("TextButton")
    Btn.Parent = ToggleMain
    Btn.Size = UDim2.new(1, 0, 1, 0)
    Btn.BackgroundTransparency = 1
    Btn.Text = ""

    local Toggled = false
    Btn.MouseButton1Click:Connect(function()
        Toggled = not Toggled
        if Toggled then
            TS:Create(SwitchBg, TweenInfo.new(0.2), {BackgroundColor3 = Theme.Accent}):Play()
            TS:Create(Circle, TweenInfo.new(0.2), {Position = UDim2.new(1, -16, 0.5, 0), BackgroundColor3 = Theme.Text}):Play()
            SwitchStroke.Color = Theme.Accent
        else
            TS:Create(SwitchBg, TweenInfo.new(0.2), {BackgroundColor3 = Theme.Main}):Play()
            TS:Create(Circle, TweenInfo.new(0.2), {Position = UDim2.new(0, 2, 0.5, 0), BackgroundColor3 = Theme.TextDark}):Play()
            SwitchStroke.Color = Theme.Border
        end
        if Callback then Callback(Toggled) end
    end)
end

local function CreateSlider(Parent, Text, Min, Max, Default, Callback)
    local SliderMain = Instance.new("Frame")
    SliderMain.Parent = Parent
    SliderMain.Size = UDim2.new(1, -5, 0, 48)
    SliderMain.BackgroundColor3 = Theme.Card
    Instance.new("UICorner", SliderMain).CornerRadius = UDim.new(0, 6)
    
    local SliderStroke = Instance.new("UIStroke")
    SliderStroke.Parent = SliderMain
    SliderStroke.Color = Theme.Border
    SliderStroke.Thickness = 1

    local Label = Instance.new("TextLabel")
    Label.Parent = SliderMain
    Label.BackgroundTransparency = 1
    Label.Position = UDim2.new(0, 10, 0, 5)
    Label.Size = UDim2.new(0.5, 0, 0, 20)
    Label.Font = Enum.Font.GothamMedium
    Label.Text = Text
    Label.TextSize = 13
    Label.TextColor3 = Theme.Text
    Label.TextXAlignment = Enum.TextXAlignment.Left

    local ValueLbl = Instance.new("TextLabel")
    ValueLbl.Parent = SliderMain
    ValueLbl.BackgroundTransparency = 1
    ValueLbl.Position = UDim2.new(0.5, -10, 0, 5)
    ValueLbl.Size = UDim2.new(0.5, 0, 0, 20)
    ValueLbl.Font = Enum.Font.GothamBold
    ValueLbl.Text = tostring(Default)
    ValueLbl.TextSize = 12
    ValueLbl.TextColor3 = Theme.Accent
    ValueLbl.TextXAlignment = Enum.TextXAlignment.Right

    local BarBg = Instance.new("Frame")
    BarBg.Parent = SliderMain
    BarBg.Position = UDim2.new(0, 10, 0, 32)
    BarBg.Size = UDim2.new(1, -20, 0, 6)
    BarBg.BackgroundColor3 = Theme.Main
    Instance.new("UICorner", BarBg).CornerRadius = UDim.new(1, 0)
    
    local BarStroke = Instance.new("UIStroke")
    BarStroke.Parent = BarBg
    BarStroke.Color = Theme.Border
    BarStroke.Thickness = 1

    local BarFill = Instance.new("Frame")
    BarFill.Parent = BarBg
    BarFill.Size = UDim2.new((Default - Min) / (Max - Min), 0, 1, 0)
    BarFill.BackgroundColor3 = Theme.Accent
    Instance.new("UICorner", BarFill).CornerRadius = UDim.new(1, 0)

    local Btn = Instance.new("TextButton")
    Btn.Parent = BarBg
    Btn.Size = UDim2.new(1, 0, 1, 0)
    Btn.Position = UDim2.new(0, 0, 0, -5)
    Btn.Size = UDim2.new(1, 0, 1, 10)
    Btn.BackgroundTransparency = 1
    Btn.Text = ""

    local Dragging = false
    Btn.MouseButton1Down:Connect(function() Dragging = true end)
    UIS.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then Dragging = false end end)

    game:GetService("RunService").RenderStepped:Connect(function()
        if Dragging then
            local mouseX = UIS:GetMouseLocation().X
            local percent = math.clamp((mouseX - BarBg.AbsolutePosition.X) / BarBg.AbsoluteSize.X, 0, 1)
            local value = math.floor(Min + ((Max - Min) * percent))
            
            BarFill.Size = UDim2.new(percent, 0, 1, 0)
            ValueLbl.Text = tostring(value)
            if Callback then Callback(value) end
        end
    end)
end

